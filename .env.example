# Google Gemini API Key — 用于 AI 情绪荐书功能
# 获取地址: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Theory Desk 品牌门店主页（可选）
# 默认使用站内临时页 /theory-desk；有独立域名后改为完整 URL，例如：
# NEXT_PUBLIC_THEORY_DESK_URL=https://theorydesk.com

# NextAuth（登录功能必填 AUTH_SECRET，否则页面报错）
# 本地开发可使用下方示例值，生产环境请换成随机密钥
AUTH_SECRET=reading-universe-local-dev-secret-change-me
AUTH_TRUST_HOST=true

# Google 登录（可选，配置后启用）
# AUTH_GOOGLE_ID=your_google_client_id
# AUTH_GOOGLE_SECRET=your_google_client_secret

# 管理员后台（不对外展示入口，使用管理员邮箱密码在 /login 登录）
ADMIN_EMAIL=admin@theorydesk.com
ADMIN_PASSWORD=change-this-password
